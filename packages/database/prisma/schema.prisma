// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "./generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// CATEGORY  (e.g. Appetizers, Mains, Desserts)
// ─────────────────────────────────────────────
model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  sortOrder   Int        @default(0)
  menuItems   MenuItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ─────────────────────────────────────────────
// MENU ITEM
// ─────────────────────────────────────────────
model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  isAvailable Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  isVegetarian Boolean @default(false)
  isSpicy     Boolean  @default(false)
  modifiers   Json?    // Array of ModifierGroup: [{name, type, required, options:[{label,price}]}]

  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  String

  orderItems  OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────
model Order {
  id          String      @id @default(cuid())
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(10, 2)
  notes       String?

  customer    Customer    @relation(fields: [customerId], references: [id])
  customerId  String

  orderItems  OrderItem[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum OrderStatus {
  PENDING
  PREPARING
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────
// ORDER ITEM  (line items within an Order)
// ─────────────────────────────────────────────
model OrderItem {
  id         String   @id @default(cuid())
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String

  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId String

  createdAt  DateTime @default(now())
}

// ─────────────────────────────────────────────
// CUSTOMER
// ─────────────────────────────────────────────
model Customer {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  passwordHash String?  // null for guest-checkout customers
  orders       Order[]

  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// RESERVATION
// ─────────────────────────────────────────────
model Reservation {
  id           String            @id @default(cuid())
  date         DateTime
  time         String            // e.g. "19:00"
  partySize    Int
  status       ReservationStatus @default(PENDING)
  specialNotes String?

  customer     Customer          @relation(fields: [customerId], references: [id])
  customerId   String

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
